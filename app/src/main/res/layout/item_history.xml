<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#0D0D0D"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Time -->
<!--        <TextView-->
<!--            android:id="@+id/tvHistoryTime"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:text="10:45 PM"-->
<!--            android:textColor="#60FFD080"-->
<!--            android:textSize="11sp"-->
<!--            android:textStyle="bold"-->
<!--            android:letterSpacing="0.06"-->
<!--            android:layout_marginBottom="10dp"/>-->
        <!-- Top Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvHistoryTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10:45 PM"
                android:textColor="#60FFD080"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"/>

            <TextView
                android:id="@+id/tvHistoryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NORMAL"
                android:textColor="#4ADE80"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/badge_bg_green"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"/>

        </LinearLayout>
        <!-- Vitals row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- SpO2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tvHistorySpo2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="98.2%"
                    android:textColor="#7EC8FF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SpO₂"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- HR -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❤️"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tvHistoryHr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="71 bpm"
                    android:textColor="#FF8090"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Heart Rate"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Temp -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌡️"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tvHistoryTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="36.6°C"
                    android:textColor="#FFD060"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Temp"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>